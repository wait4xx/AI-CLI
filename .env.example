# ============================================================
# AI-CLI-Mobile 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ─── 必需配置 ───

# JWT 密钥（至少 32 个字符，生产环境请使用随机强密钥）
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-characters-long

# ─── 可选配置（带默认值）───

# 运行环境: development | production | test
NODE_ENV=development

# 服务端口
PORT=18333

# 项目根目录（CLI 工具的工作目录）
PROJECT_ROOT=/workspace

# 管理员账号（密码至少 8 位）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=***

# CORS 允许的来源（多个用逗号分隔，留空则开发模式允许所有）
# CORS_ORIGINS=http://localhost:18333,https://yourdomain.com

# 日志级别: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# 默认 Shell 命令
SHELL_CMD=bash

# 运行时数据目录（会话、用户、审计日志等，默认为项目根目录下的 data/）
# DATA_DIR=/opt/ai-cli/data

# ─── WebSocket URL（前端使用，Vite 注入）───
# VITE_WS_URL=ws://localhost:18333
